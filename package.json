{
  "name": "pediassist",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npx prisma generate && npm run build && electron-builder",
    "test:vaccination": "node tests/vaccination-records.test.cjs",
    "test:revaccination": "node tests/polio-hib-revaccination.test.cjs",
    "test:vidal": "node tests/vidal-parser-test.cjs",
    "test:cdss-cli": "node scripts/run-cdss-cli.cjs",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "build": {
    "appId": "com.pediassist.app",
    "productName": "PediAssist",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "public/print-certificate.html",
      "prisma/**/*",
      "node_modules/@prisma/**/*",
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma",
        "filter": [
          "**/*"
        ]
      },
      "node_modules/better-sqlite3/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/client/**/*",
      "**/*.node"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "@journeyapps/sqlcipher": "^5.3.1",
    "@prisma/adapter-better-sqlite3": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lodash": "^4.17.23",
    "lucide-react": "^0.562.0",
    "pdfjs-dist": "^5.4.530",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "remark-gfm": "^4.0.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.4.0",
    "winston": "^3.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/lodash": "^4.17.23",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "prisma": "^7.2.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.3"
  }
}
