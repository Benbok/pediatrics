  "qualityCheckRules": {
    "form_validation": {
      "description": "Validate form structure",
      "checks": [
        "form.id must be unique for medication",
        "form.type must be one of availableFormTypes",
        "form.description must not be empty",
        "form.description must be in Russian",
        "concentration and unit should be consistent"
      ]
    },
    "dosing_validation": {
      "description": "Validate dosing information",
      "checks": [
        "dosing.type must be one of: weight_based, fixed, age_based",
        "maxSingleDose must be >= dose calculation",
        "maxDailyDose must be >= maxSingleDose * timesPerDay",
        "intervalHours must be reasonable (1-24)",
        "timesPerDay must be reasonable (1-6)",
        "instructions must be in Russian"
      ]
    },
    "pediatric_dosing_validation": {
      "description": "Additional checks for pediatric dosing",
      "checks": [
        "maxAgeMonths must be > minAgeMonths",
        "age ranges should not overlap",
        "formId must exist in medication.forms",
        "weight-based dosing for infants should have weight limits",
        "Should have instructions for parent/caregiver"
      ]
    }
  },
  "aiTaskTemplates": {
    "recognizeFormFromDescription": {
      "instruction": "Given Russian medication form description, identify form type, strength, and packaging",
      "input": "string (Russian description)",
      "output": {
        "formType": "string",
        "strength": "number",
        "strengthUnit": "string",
        "packaging": "string",
        "volume": "number",
        "volumeUnit": "string"
      }
    },
    "generateDosingRecommendation": {
      "instruction": "Generate pediatric dosing for given age and weight range",
      "input": {
        "medication": "object",
        "ageMonths": "number",
        "weightKg": "number"
      },
      "output": {
        "dosage": "number",
        "unit": "string",
        "timesPerDay": "number",
        "maxDailyDose": "number",
        "formRecommendation": "string"
      }
    },
    "validateMedicationData": {
      "instruction": "Validate complete medication record against quality rules",
      "input": "object (full medication record)",
      "output": {
        "isValid": "boolean",
        "errors": ["string"],
        "warnings": ["string"]
      }
    },
    "enrichMedicationForm": {
      "instruction": "Extract and structure form details from unstructured text",
      "input": "string (unstructured Russian description)",
      "output": "object (structured form)"
    }
  },
