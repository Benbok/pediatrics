# PediAssist - Environment Variables
# Copy this file to .env.local and fill in your API keys

# Google Gemini API (required for AI diagnostic assistant)
# Get your key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Security & Database (Medical Grade)
# Random 32+ character string for DB encryption
# This key is used for field-level encryption of PII (Names, Birthdates)
DB_ENCRYPTION_KEY=FiZjvcog7JSBjFS7j5GDgXlQPemMehcv

# Admin Authentication (Initial credentials)
# You can use a plain text password for first run, then replace with bcrypt hash
# e.g. $2a$10$YourHash...
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
